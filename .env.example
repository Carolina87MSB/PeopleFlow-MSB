# Copie este arquivo para .env.local (ignorado pelo git) e preencha com os
# valores do MESMO projeto Supabase usado pelo Portal SST MSB — os dois
# portais compartilham a tabela `colaboradores` (mesmas pessoas) e o mesmo
# Supabase Auth (mesmos e-mails provisionados).
#
# IMPORTANTE: este projeto é Vite (não Next.js) — só variáveis com prefixo
# VITE_ chegam ao navegador. Não use NEXT_PUBLIC_*, não funciona aqui.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
# No painel do Supabase esse valor aparece como "Publishable key" (antigo nome: "anon key").
VITE_SUPABASE_PUBLISHABLE_KEY=SUA_PUBLISHABLE_KEY

# Usada só pelas Vercel Serverless Functions em api/*.ts (nunca roda no navegador) e pelo
# scripts/seed-supabase.mjs. No painel do Supabase aparece como "Secret key" (antigo nome:
# "service_role key"). NUNCA prefixe com VITE_ (ficaria exposta no bundle do navegador) e
# NUNCA a exponha fora de env vars de servidor (local .env.local ou Vercel server-side).
SUPABASE_SERVICE_ROLE_KEY=SUA_SECRET_KEY

# Usadas só por api/notificar.ts (servidor) para enviar as notificações de
# movimentação do fluxo de aprovação por e-mail via Gmail SMTP. GMAIL_APP_PASSWORD
# é uma "Senha de app" do Google (myaccount.google.com/apppasswords) — exige
# verificação em 2 etapas habilitada na conta —, NÃO a senha normal do Gmail.
# Sem estas variáveis (local ou na Vercel), o envio é pulado silenciosamente
# (o fluxo de aprovação continua funcionando normalmente, só sem e-mail).
GMAIL_USER=seu-email@gmail.com
GMAIL_APP_PASSWORD=SUA_SENHA_DE_APP_DE_16_CARACTERES
